HOST=127.0.0.1
PORT=8787
CORS_ORIGIN=http://127.0.0.1:3000,http://localhost:3000
WEB_URL=http://127.0.0.1:8787
SITE_NAME=AstrBot Community Plugins
SITE_ICON_URL=/logo.webp
SITE_SUBTITLE=全新社区插件市场
SITE_DESCRIPTION=发现、评价和提交 AstrBot 插件。
SITE_CONTACT_EMAIL=
SITE_DOCS_URL=https://docs.astrbot.app/dev/star/plugin-new.html
GITHUB_LOGIN_ENABLED=false
PUBLIC_LOGIN_ENABLED=true
LOGIN_AGREEMENT_ENABLED=false
LOGIN_AGREEMENT_TEXT=
SERVICE_TERMS_ENABLED=false
SERVICE_TERMS_TEXT=

GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
# Leave empty and configure this in `/settings`, unless you want an environment override.
GITHUB_CALLBACK_URL=
GITHUB_SCOPE=read:user user:email read:org
GITHUB_ADMIN_ORG=

MARKET_SUBMISSIONS_ENABLED=true
MARKET_COMMENTS_ENABLED=true
MARKET_LIKES_ENABLED=true
PLUGIN_AUTO_APPROVE_ENABLED=false
MAX_PLUGIN_TAGS=8

EMAIL_PROVIDER=disabled
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_SSL=false
CLOUDFLARE_EMAIL_ACCOUNT_ID=
CLOUDFLARE_EMAIL_API_TOKEN=
CLOUDFLARE_EMAIL_FROM=
EMAIL_DAILY_LIMIT=0
EMAIL_VERIFICATION_DAILY_LIMIT_PER_USER=5

# Leave empty on first launch and configure these from the web `/setup` page.
DATABASE_URL=
REDIS_URL=

SESSION_COOKIE_NAME=astrbot_market_session
OAUTH_STATE_COOKIE_NAME=astrbot_market_oauth_state
COOKIE_SAME_SITE=Lax
COOKIE_SECURE=false
SESSION_MAX_AGE_SECONDS=604800

ENABLE_DEV_AUTH=true
MARKET_API_KEYS=local:dev-market-key:market:read|market:write
