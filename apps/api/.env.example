GITHUB_SCOPE=read:user user:email read:org
GITHUB_ADMIN_ORG=

# Leave empty on first launch and configure these from the web `/setup` page.
DATABASE_URL=
REDIS_URL=

SESSION_COOKIE_NAME=astrbot_market_session
OAUTH_STATE_COOKIE_NAME=astrbot_market_oauth_state
COOKIE_SAME_SITE=Lax
COOKIE_SECURE=false
SESSION_MAX_AGE_SECONDS=604800

ENABLE_DEV_AUTH=true
MARKET_API_KEYS=local:dev-market-key:market:read|market:write
